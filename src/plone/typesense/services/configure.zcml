<configure
    xmlns="http://namespaces.zope.org/zope"
    xmlns:plone="http://namespaces.plone.org/plone"
    i18n_domain="plone.typesense">

  <include package="plone.restapi" file="meta.zcml" />

  <plone:service
      method="GET"
      for="Products.CMFPlone.interfaces.IPloneSiteRoot"
      factory=".typesense.TypesenseInfo"
      name="@typesense-info"
      permission="cmf.ManagePortal"
      layer="plone.typesense.interfaces.IPloneTypesenseLayer"
      />

  <plone:service
      method="POST"
      for="Products.CMFPlone.interfaces.IPloneSiteRoot"
      factory=".typesense.TypesenseConvert"
      name="@typesense-convert"
      permission="cmf.ManagePortal"
      layer="plone.typesense.interfaces.IPloneTypesenseLayer"
      />

  <plone:service
      method="POST"
      for="Products.CMFPlone.interfaces.IPloneSiteRoot"
      factory=".typesense.TypesenseRebuild"
      name="@typesense-rebuild"
      permission="cmf.ManagePortal"
      layer="plone.typesense.interfaces.IPloneTypesenseLayer"
      />

  <plone:service
      method="POST"
      for="Products.CMFPlone.interfaces.IPloneSiteRoot"
      factory=".typesense.TypesenseSync"
      name="@typesense-sync"
      permission="cmf.ManagePortal"
      layer="plone.typesense.interfaces.IPloneTypesenseLayer"
      />

</configure>
